FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# 基础工具（用默认 Ubuntu 源）
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates python3 python3-pip python3-venv git jq \
    && rm -rf /var/lib/apt/lists/*

# 预装 NVM + Node 22 + opencode
ENV NVM_DIR=/root/.nvm
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.2/install.sh | bash \
    && . "$NVM_DIR/nvm.sh" \
    && nvm install 22 \
    && npm i -g opencode-ai@latest \
    && echo '. "$NVM_DIR/nvm.sh"' >> /root/.bashrc

# 预置 opencode 配置：用 custom provider 走 chat/completions
RUN mkdir -p /root/.config/opencode && echo '{\
  "provider":{"custom":{"npm":"@ai-sdk/openai-compatible","name":"Copilot",\
  "options":{"baseURL":"http://host.docker.internal:4141/v1","apiKey":"_"},\
  "models":{"gpt-5.2":{"name":"GPT-5.2"},"gpt-4o-mini":{"name":"GPT-4o Mini"}}}},\
  "model":"custom/gpt-5.2"\
}' > /root/.config/opencode/opencode.json

# 验证
RUN . "$NVM_DIR/nvm.sh" && opencode --version

WORKDIR /root
