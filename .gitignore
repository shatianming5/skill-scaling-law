# Results (large files, regenerable)
results/rq1/*
results/rq2/*
results/rq3/*

# Keep directory structure
!results/rq1/.gitkeep
!results/rq2/.gitkeep
!results/rq3/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# API keys
.env
.env.local

# Auto-generated skills may contain leaked secrets from OpenClaw
data/skills/auto_generated/*
!data/skills/auto_generated/.gitkeep
